# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# OMDB API key — free at https://www.omdbapi.com/apikey.aspx  (1,000 req/day)
OMDB_API_KEY=your_omdb_key_here

# Public app URL (set to your Cloudflare Workers domain in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: future backend API base URL
NEXT_PUBLIC_API_URL=https://api.scriptmind.ai/v1
